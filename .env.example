# Runtime source: committed publication surface consumed by local runtime, CI, docs, and deploy.
FPF_SPEC_SOURCE_PATH=published/current/FPF-Spec.md
# Local publish source: gitignored upstream working copy used by `publish:current` / pre-push.
# Canonical upstream (sync repo): https://github.com/venikman/fpf-sync — file FPF/FPF-Spec.md on main.
# Option A — local git checkout:
# FPF_PUBLISH_SOURCE_PATH=/absolute/path/to/fpf-sync/FPF/FPF-Spec.md
# Option B — download the pinned upstream into the default gitignored location:
#   bun run spec:download
#   (writes .fpf-upstream/FPF-Spec.md; keep the line below)
FPF_PUBLISH_SOURCE_PATH=.fpf-upstream/FPF-Spec.md
FPF_RUNTIME_ARTIFACT_DIR=.runtime/fpf-index
FPF_QUERY_DEFAULT_MODE=verbose
# Optional LM Studio path. If you set either base URL or model, the missing half
# falls back to the repo defaults below.
# The runtime talks to LM Studio's Anthropic-compatible endpoints only:
# POST {FPF_LOCAL_LLM_BASE_URL}/messages for generation, GET .../models for discovery.
FPF_LOCAL_LLM_BASE_URL=http://localhost:1234/v1
FPF_LOCAL_LLM_MODEL=google/gemma-4-31b
FPF_LOCAL_LLM_API_KEY=
FPF_LOCAL_LLM_TIMEOUT_MS=20000
FPF_MASTRA_LOG_PATH=.runtime/logs/mastra.log
FPF_MASTRA_LOG_LEVEL=info
FPF_MASTRA_OBSERVABILITY_PATH=.runtime/logs/mastra-observability.json
FPF_MASTRA_OBSERVABILITY_FORMAT=flat
FPF_MASTRA_OBSERVABILITY_INCLUDE_INTERNAL_SPANS=true
FPF_MASTRA_OBSERVABILITY_INCLUDE_MODEL_CHUNKS=false
FPF_MASTRA_OBSERVABILITY_LOG_LEVEL=info
FPF_AI_TRACE_LOG_PATH=.runtime/logs/ai-traces.jsonl
