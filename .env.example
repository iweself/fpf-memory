# Runtime source: committed publication surface consumed by local runtime, CI, docs, and deploy.
FPF_SPEC_SOURCE_PATH=published/current/FPF-Spec.md
# Local publish source: gitignored upstream working copy used by `publish:current` / pre-push.
# Canonical upstream: https://github.com/ailev/FPF — file FPF-Spec.md on main.
FPF_UPSTREAM_OWNER=ailev
FPF_UPSTREAM_REPO=FPF
FPF_UPSTREAM_REF=main
FPF_UPSTREAM_SPEC_PATH=FPF-Spec.md
# Option A — local git checkout:
# FPF_PUBLISH_SOURCE_PATH=/absolute/path/to/FPF/FPF-Spec.md
# Option B — download the pinned upstream into the default gitignored location:
#   bun run spec:download
#   (writes .fpf-upstream/FPF-Spec.md; keep the line below)
FPF_PUBLISH_SOURCE_PATH=.fpf-upstream/FPF-Spec.md
FPF_SYNC_MONITOR_STATUS_URL=https://fpf.sh/api/fpf/status
FPF_SYNC_MONITOR_MAX_DRIFT_HOURS=10
FPF_VERCEL_PROJECT=fpf-sh
# Optional team scope for Vercel metrics queries, for example team_CnO1I5xd2OS0lzbbc4RkW7Ym.
FPF_VERCEL_SCOPE=
FPF_VERCEL_SPEND_WINDOW_MINUTES=30
FPF_VERCEL_SPEND_MAX_FUNCTION_DURATION_GBHR=0.25
FPF_VERCEL_SPEND_MAX_LEGACY_INVOCATIONS=0
FPF_VERCEL_SPEND_MAX_ERROR_INVOCATIONS=0
FPF_VERCEL_SPEND_LEGACY_PATH=/api/mcp/fpf_memory
FPF_VERCEL_FUNCTION_DURATION_USD_PER_GBHR=0.18
FPF_RUNTIME_ARTIFACT_DIR=.runtime/fpf-index
FPF_QUERY_DEFAULT_MODE=verbose
# Emergency production switch: when true, hosted /api/mcp/* returns a cheap 503
# before loading the MCP runtime. Static docs and /api/fpf/status stay available.
FPF_HOSTED_MCP_DISABLED=false
# Optional LM Studio path. If you set either base URL or model, the missing half
# falls back to the repo defaults below.
# The runtime talks to LM Studio's Anthropic-compatible endpoints only:
# POST {FPF_LOCAL_LLM_BASE_URL}/messages for generation, GET .../models for discovery.
FPF_LOCAL_LLM_BASE_URL=http://localhost:1234/v1
FPF_LOCAL_LLM_MODEL=google/gemma-4-31b
FPF_LOCAL_LLM_API_KEY=
FPF_LOCAL_LLM_TIMEOUT_MS=20000
FPF_RUNTIME_LOG_PATH=.runtime/logs/fpf-runtime.log
FPF_RUNTIME_LOG_LEVEL=info
FPF_RUNTIME_OBSERVABILITY_PATH=.runtime/logs/runtime-observability.json
FPF_RUNTIME_OBSERVABILITY_FORMAT=flat
FPF_RUNTIME_OBSERVABILITY_INCLUDE_INTERNAL_SPANS=true
FPF_RUNTIME_OBSERVABILITY_INCLUDE_MODEL_CHUNKS=false
FPF_RUNTIME_OBSERVABILITY_LOG_LEVEL=info
FPF_AI_TRACE_LOG_PATH=.runtime/logs/ai-traces.jsonl
