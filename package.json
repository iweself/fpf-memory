{
  "name": "fpf-memory",
  "version": "1.0.0",
  "description": "Bun-first compiler-backed FPF spec runtime exposed through hosted Vercel and local MCP surfaces with a Hono server engine.",
  "packageManager": "bun@1.3.5",
  "bin": "dist/stdio.js",
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "bun --watch src/server.ts",
    "start": "bun src/server.ts",
    "cli": "bun src/cli.ts",
    "mcp": "bun src/entrypoints/mcp-stdio.ts",
    "spec:download": "bun scripts/download-upstream-spec.ts",
    "publish:current": "bun scripts/publish-current.ts",
    "validate:published": "bun scripts/validate-published-current.ts",
    "monitor:sync": "bun scripts/monitor-fpf-sync.ts",
    "monitor:content": "bun scripts/monitor-content-quality.ts",
    "monitor:vercel:spend": "bun scripts/monitor-vercel-spend.ts",
    "evaluate:work": "bun src/cli.ts evaluate-work --target current-pr --base origin/main --format markdown",
    "stage:from-published": "bun scripts/stage-from-published.ts",
    "smoke:mcp:http": "bun scripts/smoke-hosted-mcp.ts",
    "bench:mcp": "bun scripts/bench-hosted-mcp.ts",
    "bench:mcp:qa": "bun scripts/bench-mcp-qa.ts",
    "bench:mcp:series": "bun scripts/bench-hosted-mcp-series.ts",
    "bench:vercel:function-size": "bun scripts/check-vercel-function-size.ts",
    "vercel:origin:link": "vercel link --project fpf-sh",
    "vercel:origin:build": "bun run predeploy && bun run docs:build && bun run build:vercel-origin && bun run bench:vercel:function-size",
    "vercel:origin:deploy": "bun run vercel:origin:build && vercel deploy --prebuilt --yes",
    "vercel:origin:deploy:prod": "bun run vercel:origin:build && vercel deploy --prebuilt --prod --yes",
    "build": "bun run build:runtime && bun run build:mcp",
    "build:runtime": "bun build ./src/cli.ts ./src/server.ts --outdir dist --target bun",
    "build:mcp": "bun build ./src/entrypoints/mcp-stdio.ts --outfile dist/stdio.js --target node --format esm && bun scripts/fixup-stdio-build.ts",
    "build:vercel-origin": "bun scripts/build-vercel-origin.ts",
    "docs:generate": "bun scripts/generate-docs.ts",
    "docs:dev": "bun run docs:generate && rspress",
    "docs:dev:fresh": "bun run docs:generate && RSPRESS_PERSISTENT_CACHE=false rspress",
    "docs:build": "bun run docs:generate && RSPRESS_PERSISTENT_CACHE=false rspress build",
    "docs:preview": "RSPRESS_PERSISTENT_CACHE=false rspress preview",
    "hooks:install": "bun scripts/install-hooks.ts",
    "lint": "rslint --type-check src tests scripts/*.ts *.config.ts",
    "check": "tsc --noEmit",
    "check:boundaries": "bun scripts/check-boundaries.ts",
    "test": "rstest run",
    "test:ci": "rstest run --shard=1/4 && rstest run --shard=2/4 && rstest run --shard=3/4 && rstest run --shard=4/4",
    "test:e2e": "playwright test",
    "test:e2e:install": "playwright install --with-deps chromium",
    "predeploy": "bun run stage:from-published",
    "deploy": "bun run vercel:origin:deploy:prod"
  },
  "license": "ISC",
  "type": "module",
  "engines": {
    "node": ">=22.13.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "hono": "^4.12.12",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@rslint/core": "^0.4.1",
    "@rspress/core": "^2.0.9",
    "@rstest/core": "^0.9.7",
    "@types/node": "^25.6.0",
    "bun-types": "^1.3.12",
    "typescript": "^6.0.2"
  }
}
