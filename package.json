{
  "name": "fpf-memory",
  "version": "1.0.0",
  "description": "Bun-first compiler-backed FPF spec runtime exposed through hosted and local Mastra MCP surfaces with a Hono server engine.",
  "packageManager": "bun@1.3.5",
  "bin": "dist/stdio.js",
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "bun --watch src/server.ts",
    "start": "bun src/server.ts",
    "cli": "bun src/cli.ts",
    "mcp": "bun src/mastra/stdio.ts",
    "spec:download": "bun scripts/download-upstream-spec.ts",
    "build": "bun run build:runtime && bun run build:mcp",
    "build:runtime": "bun build ./src/cli.ts ./src/server.ts --outdir dist --target bun",
    "build:mcp": "tsup src/mastra/stdio.ts --format esm --out-dir dist --no-splitting && bun scripts/fixup-stdio-build.ts",
    "docs:generate": "bun scripts/generate-docs.ts",
    "docs:dev": "bun run docs:generate && rspress",
    "docs:dev:fresh": "bun run docs:generate && RSPRESS_PERSISTENT_CACHE=false rspress",
    "docs:build": "bun run docs:generate && RSPRESS_PERSISTENT_CACHE=false rspress build",
    "docs:preview": "RSPRESS_PERSISTENT_CACHE=false rspress preview",
    "lint": "rslint --type-check src tests scripts/*.ts *.config.ts",
    "check": "tsc --noEmit",
    "check:boundaries": "bun scripts/check-boundaries.ts",
    "test": "rstest run",
    "predeploy": "bun run spec:download && bun scripts/prepare-deploy.ts",
    "deploy": "bun run predeploy && bunx mastra build && bunx mastra server deploy --yes"
  },
  "license": "ISC",
  "type": "module",
  "engines": {
    "node": ">=22.13.0"
  },
  "dependencies": {
    "@mastra/core": "^1.24.1",
    "@mastra/hono": "^1.4.3",
    "@mastra/loggers": "^1.1.1",
    "@mastra/mcp": "^1.4.2",
    "@mastra/observability": "^1.9.0",
    "hono": "^4.12.12",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@rslint/core": "^0.4.1",
    "@rspress/core": "^2.0.9",
    "@rstest/core": "^0.9.7",
    "@types/node": "^25.6.0",
    "bun-types": "^1.3.12",
    "mastra": "^1.5.0",
    "tsup": "^8.5.1",
    "typescript": "^6.0.2"
  }
}
