{
  "name": "fpf_reference",
  "version": "1.0.0",
  "description": "Optional local full-surface FPF Reference MCP runtime for expert clients.",
  "transport": "stdio",
  "command": "bun",
  "cwd": ".",
  "args": ["src/entrypoints/mcp-stdio.ts"],
  "env": {
    "FPF_SPEC_SOURCE_PATH": "published/current/FPF-Spec.md",
    "FPF_RUNTIME_ARTIFACT_DIR": ".runtime/fpf-index",
    "FPF_MCP_SURFACE": "full"
  }
}
