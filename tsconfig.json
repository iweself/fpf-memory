{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "outDir": "dist",
    "types": ["node", "bun-types"]
  },
  "include": [
    "src/**/*",
    "tests/**/*",
    "scripts/**/*",
    "rslint.config.ts",
    "rstest.config.ts",
    "rspress.config.ts"
  ]
}
